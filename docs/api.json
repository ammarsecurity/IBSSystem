    "components": {
      "schemas": {
        "AuthResponseDto": {
          "type": "object",
          "properties": {
            "userId": {
              "type": "integer",
              "format": "int32"
            },
            "fullName": {
              "type": "string",
              "nullable": true
            },
            "mobile": {
              "type": "string",
              "nullable": true
            },
            "accessToken": {
              "type": "string",
              "nullable": true
            },
            "isSuccess": {
              "type": "boolean"
            },
            "error": {
              "type": "string",
              "nullable": true
            },
            "issuedAt": {
              "type": "string",
              "format": "date-time",
              "nullable": true
            },
            "expiresAt": {
              "type": "string",
              "format": "date-time",
              "nullable": true
            }
          },
          "additionalProperties": false
        },
        "DtoActivation": {
          "type": "object",
          "properties": {
            "id": {
              "type": "integer",
              "format": "int32"
            },
            "creationDate": {
              "type": "string",
              "format": "date-time"
            },
            "profile": {
              "type": "string",
              "nullable": true
            },
            "saleType": {
              "type": "boolean"
            },
            "cost": {
              "type": "number",
              "format": "double"
            }
          },
          "additionalProperties": false
        },
        "DtoCreatePaymentRequest": {
          "required": [
            "amount"
          ],
          "type": "object",
          "properties": {
            "amount": {
              "maximum": 1.7976931348623157E+308,
              "minimum": 0.01,
              "type": "number",
              "format": "double"
            },
            "returnUrl": {
              "type": "string",
              "nullable": true
            }
          },
          "additionalProperties": false
        },
        "DtoFinancialInfo": {
          "type": "object",
          "properties": {
            "userId": {
              "type": "integer",
              "format": "int32"
            },
            "amountDue": {
              "type": "number",
              "format": "double"
            },
            "debtLimit": {
              "type": "number",
              "format": "double",
              "nullable": true
            },
            "canActiveNoCash": {
              "type": "boolean"
            },
            "lastActivation": {
              "type": "string",
              "format": "date-time",
              "nullable": true
            }
          },
          "additionalProperties": false
        },
        "DtoReceivable": {
          "type": "object",
          "properties": {
            "id": {
              "type": "integer",
              "format": "int32"
            },
            "creationDate": {
              "type": "string",
              "format": "date-time"
            },
            "amount": {
              "type": "number",
              "format": "double"
            }
          },
          "additionalProperties": false
        },
        "DtoRefillRequest": {
          "required": [
            "profileId"
          ],
          "type": "object",
          "properties": {
            "saleType": {
              "type": "boolean"
            },
            "profileId": {
              "type": "integer",
              "format": "int32"
            }
          },
          "additionalProperties": false
        },
        "LoginRequestDto": {
          "type": "object",
          "properties": {
            "mobile": {
              "type": "string",
              "nullable": true
            },
            "company": {
              "type": "string",
              "nullable": true
            }
          },
          "additionalProperties": false
        },
        "Response": {
          "type": "object",
          "properties": {
            "error": {
              "type": "boolean"
            },
            "message": {
              "type": "string",
              "nullable": true
            },
            "data": {
              "nullable": true
            }
          },
          "additionalProperties": false
        }
      },
      "securitySchemes": {
        "Bearer": {
          "type": "http",
          "description": "Enter JWT token",
          "scheme": "bearer",
          "bearerFormat": "JWT"
        }
      }
    },
    "security": [
      {
        "Bearer": [ ]
      }
    ],
    "tags": [
      {
        "name": "Auth"
      },
      {
        "name": "Subscriber"
      }
    ]
