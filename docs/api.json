                }
              },
              "application/*+json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginRequestDto"
                }
              }
            }
          },
          "responses": {
            "200": {
              "description": "OK",
              "content": {
                "text/plain": {
                  "schema": {
                    "$ref": "#/components/schemas/AuthResponseDto"
                  }
                },
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/AuthResponseDto"
                  }
                },
                "text/json": {
                  "schema": {
                    "$ref": "#/components/schemas/AuthResponseDto"
                  }
                }
              }
            }
          }
        }
      },
